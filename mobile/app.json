{
  "expo": {
    "name": "Muestra Invernal de Tela y Aro",
    "slug": "telas-scanner",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./src/theme/icon-1024.png",
    "splash": {
      "backgroundColor": "#120B29",
      "image": "./src/theme/icon.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.telas.scanner",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para escanear QR de entradas"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#120B29"
      },
      "package": "com.telas.scanner",
      "permissions": ["android.permission.CAMERA", "android.permission.WRITE_EXTERNAL_STORAGE", "android.permission.READ_EXTERNAL_STORAGE"],
      "usesCleartextTraffic": true
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos acceso a la cámara para escanear QR de entradas"
        }
      ]
    ]
  }
}
